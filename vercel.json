{
  "rewrites": [
    {
      "source": "/etc.clientlibs/:path*",
      "destination": "https://www.asisa.es/etc.clientlibs/:path*"
    },
    {
      "source": "/markup",
      "destination": "/api/markup"
    },
    {
      "source": "/markup/(.*)",
      "destination": "/api/markup?path=$1"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/sitemap-cuadro-medico-provincias.xml",
      "destination": "/api/sitemap-cuadro-medico?type=provincias"
    },
    {
      "source": "/sitemap-cuadro-medico-provincia-specs.xml",
      "destination": "/api/sitemap-cuadro-medico?type=provincia-specs"
    },
    {
      "source": "/sitemap-cuadro-medico-doctores.xml",
      "destination": "/api/sitemap-cuadro-medico?type=doctores"
    },
    {
      "source": "/sitemap-cuadro-medico-centros.xml",
      "destination": "/api/sitemap-cuadro-medico?type=centros"
    },
    {
      "source": "/sitemap-cuadro-medico-especialidades.xml",
      "destination": "/api/sitemap-cuadro-medico?type=especialidades"
    }
  ]
}
